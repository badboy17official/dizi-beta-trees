# Xiaomi Dizi (POCO Pad) Kernel Configuration
# Based on garnet_GKI.config with Dizi-specific modifications
#
# This file should be placed in:
# kernel/xiaomi/sm7435/arch/arm64/configs/vendor/dizi_GKI.config
#
# Key Differences from Garnet:
# 1. WCN6750 WiFi/BT (vs WCN3990/Adrastea in Garnet)
# 2. FM Radio support (RTC6226) - Dizi specific
# 3. No fingerprint sensor (tablet device)
# 4. No infrared remote (tablet device)
# 5. Different touchscreen controller (tablet)

# === WiFi Configuration - WCN6750 SPECIFIC ===
# Enable QCA6750 support (disabled in base parrot_GKI.config)
CONFIG_CNSS_QCA6750=y

# WiFi Driver Configuration
CONFIG_CFG80211=m
CONFIG_CNSS2=m
CONFIG_CNSS2_QMI=y
CONFIG_CNSS_UTILS=m
CONFIG_CNSS_GENL=m

# === Bluetooth Configuration - WCN6750 ===
CONFIG_BTFM_SLIM=m
CONFIG_BT=m
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_RFCOMM=m
CONFIG_BT_RFCOMM_TTY=y
CONFIG_BT_BNEP=m
CONFIG_BT_BNEP_MC_FILTER=y
CONFIG_BT_BNEP_PROTO_FILTER=y
CONFIG_BT_HIDP=m
CONFIG_BT_HS=y

# === FM Radio - RTC6226 (DIZI SPECIFIC) ===
# This is NOT in Garnet config
CONFIG_I2C_RTC6226_QCA=m
CONFIG_RADIO_RTC6226=m
CONFIG_V4L2_RADIO=y
CONFIG_MEDIA_SUPPORT=m
CONFIG_MEDIA_RADIO_SUPPORT=y

# === Battery/Fuel Gauge ===
CONFIG_BQ_FG_UPDATE=y
CONFIG_BQ_FUEL_GAUGE=y
CONFIG_HAVE_CHARGE_TEMP=y
CONFIG_MI_CHARGE_PROPERTY=y
# Wireless charging not present on Dizi (tablet)
# CONFIG_MI_WIRELESS is not set

# === Device Tree Overlay ===
CONFIG_BUILD_ARM64_DT_OVERLAY=y

# === Fingerprint - DISABLED (tablet device) ===
# Garnet has fingerprint, Dizi does not
# CONFIG_FINGERPRINT_FPC_FOD is not set
# CONFIG_FINGERPRINT_GOODIX_FOD_G3S is not set
# CONFIG_INPUT_FINGERPRINT is not set

# === HWID ===
CONFIG_MI_HARDWARE_ID=m

# === Haptics ===
# Dizi uses different haptics driver (tablet)
CONFIG_INPUT_QCOM_HV_HAPTICS=m

# === Infrared - DISABLED (tablet device) ===
# Garnet has IR remote, Dizi does not
# CONFIG_IR_SPI is not set
# CONFIG_LIRC is not set
# CONFIG_RC_CORE is not set
# CONFIG_RC_DECODERS is not set
# CONFIG_RC_DEVICES is not set

# === MTD ===
CONFIG_MTD=m
CONFIG_MTD_BLOCK2MTD=m
CONFIG_MTD_BLOCK=m
CONFIG_MTD_OOPS=m

# === Networking ===
CONFIG_NETFILTER_XT_MATCH_CONNBYTES=y

# === Regulator Drivers ===
CONFIG_REGMAP_QTI_DEBUGFS_ALLOW_WRITE=y
CONFIG_REGULATOR_QPNP_AMOLED=m
# Garnet uses WL2866D_N16, may differ on Dizi
CONFIG_REGULATOR_WL2866D_N16=m

# === SKU ===
CONFIG_BOOTCONFIG_HWC_IS_PRODUCT_SKU=y

# === SPSS ===
# CONFIG_QCOM_SPSS is not set
# CONFIG_RPMSG_QCOM_GLINK_SPSS is not set

# === Thermal ===
CONFIG_MI_THERMAL_INTERFACE=m
CONFIG_MI_THERMAL_MULTI_CHARGE=y

# === Touchscreen - TABLET SPECIFIC ===
# Dizi has different touchscreen than Garnet (phone)
# Enable generic touchscreen support, specific driver may vary
CONFIG_TOUCHSCREEN_FOCALTECH_3683G=m
CONFIG_TOUCHSCREEN_GOODIX_BRL=m
CONFIG_TOUCHSCREEN_XIAOMI_TOUCHFEATURE=m
# May need to verify actual touchscreen controller in Dizi

# === USB Networking ===
CONFIG_USB_NET_AX88179_178A=m
CONFIG_USB_NET_AX8817X=m

# === Additional Tablet-Specific Configs ===
# Hall sensor for lid detection (Dizi specific)
CONFIG_SENSORS_HALL=m
CONFIG_INPUT_HALL_SENSOR=y

# === Display - Larger tablet display ===
CONFIG_DRM=y
CONFIG_DRM_MSM=m
CONFIG_FB_MSM_MDSS=y

# === Audio - Parrot QRD configuration ===
CONFIG_SND_SOC_PARROT=m

# === Camera - 2 sensors (vs 4 on Garnet) ===
# Camera sensors are typically loaded as modules from vendor
# Specific sensor drivers (GC08A3, OV08D10) may be in vendor modules

# === Power Management ===
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
CONFIG_PM_WAKELOCKS=y

# === USB - Tablet USB configuration ===
CONFIG_USB=y
CONFIG_USB_ANNOUNCE_NEW_DEVICES=y
CONFIG_USB_CONFIGFS=m
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_CONFIGFS_F_ACC=y
CONFIG_USB_CONFIGFS_F_MTP=y
CONFIG_USB_CONFIGFS_F_PTP=y
CONFIG_USB_CONFIGFS_UEVENT=y

# === Input Devices ===
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_MISC=y

# === Sensors ===
CONFIG_SENSORS=y
CONFIG_SENSORS_SSC=y
CONFIG_MSM_QBT_HANDLER=m
